{
    "$schema": "https://biomejs.dev/schemas/latest/schema.json",
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 4,
        "lineWidth": 100
    },
    "linter": {
        "enabled": true,
        "rules": {
            "recommended": true
        }
    },
    "javascript": {
        "formatter": {
            "quoteStyle": "double",
            "semicolons": "always"
        }
    },
    "files": {
        "includes": ["src/**/*.ts", "*.json", "*.jsonc", "*.md"]
    }
}
