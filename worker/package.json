{
    "name": "resume-rag-assistant-worker",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "engines": {
        "node": "24.6.0",
        "npm": "11.5.1"
    },
    "scripts": {
        "generate-types": "wrangler types",
        "dev": "wrangler dev",
        "deploy": "wrangler deploy",
        "typecheck": "tsc --noEmit -p tsconfig.json",
        "lint": "biome lint .",
        "lint:fix": "biome lint . --write",
        "format": "biome format . --write",
        "format:check": "biome format . --write=false",
        "test": "vitest run",
        "check": "npm run typecheck && npm run lint && npm run format:check && npm run test",
        "prepare": "husky install",
        "lf": "npm run lint:fix && npm run format",
        "lc": "npm run typecheck && npm run lint && npm run format:check",
        "gt": "npm run generate-types"
    },
    "lint-staged": {
        "*.{ts,tsx,js,jsx,json,jsonc,md}": [
            "biome lint --write",
            "biome format --write"
        ]
    },
    "devDependencies": {
        "@biomejs/biome": "2.4.11",
        "husky": "9.1.7",
        "lint-staged": "16.4.0",
        "typescript": "5.9.3",
        "vitest": "3.2.4",
        "wrangler": "4.81.1"
    }
}
